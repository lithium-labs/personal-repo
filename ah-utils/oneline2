local function tableToString(tbl, indent)
	if tbl == {} then
		return "{}"
	end
	indent = indent or 0
	local toPrint = string.rep(" ", indent) .. "{\n"
	indent = indent + 2
	for k, v in pairs(tbl) do
		toPrint = toPrint .. string.rep(" ", indent)
		if type(k) ~= "string" then
			toPrint = toPrint .. "[" .. tostring(k) .. "] = "
		else
			toPrint = toPrint .. '["'..k..'"'.."] = "
		end
		if type(v) == "number" then
			toPrint = toPrint .. v .. ",\n"
		elseif type(v) == "string" then
			toPrint = toPrint .. "\"" .. v .. "\",\n"
		elseif type(v) == "table" then
			if v.line and v.type and type(v.type) == "string" and v.type:match("function") then
				toPrint = toPrint .. "function" .. ",\n"
			else
				toPrint = toPrint .. tableToString(v, indent + 2) .. ",\n"
			end
		elseif typeof(v):match("Enum") then
			toPrint = toPrint ..tostring(v)..",\n"
		elseif type(v):match("bool") then
			toPrint = toPrint ..tostring(v)..",\n"
		elseif typeof(v) == "Instance" then
			toPrint = toPrint ..tostring(v)..",\n"
		else
			toPrint = toPrint ..typeof(v).."("..tostring(v).."),\n"
		end
	end
	toPrint = toPrint .. string.rep(" ", indent-2) .. "}"
	return toPrint
end

