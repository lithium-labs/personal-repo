-- Checks if a player meets a class's RequiredRank (if the class has one set). Classes with no RequiredRank are always allowed.
local function RankAllowed(plr, classConfig)
	if not classConfig or not classConfig.RequiredRank then return true end
	local level = AdminTable.GetLevel and AdminTable.GetLevel(plr)
	return (level or 0) >= classConfig.RequiredRank
end


