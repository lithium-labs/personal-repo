			if HandleDLC(plr,"extra") then
				if npc and typeof(npc) == "Instance" and npc:HasTag("AHSLNPC") then
					if position and typeof(position) == "Vector3" then
						if not params or type(params) == "table" then
							if not params then
								params = {AgentCanClimb = true}
							end
							local path = game:GetService("PathfindingService"):CreatePath(params)
							Verify(plr,"NpcPathfinding",1)
							Log(plr,'func','NPC.WalkToPosition',npc,position)
							local a,b = pcall(function()
								path:ComputeAsync(npc.HumanoidRootPart.Position,position)
							end)
							local hadbefore
							if NPCPaths[npc] then
								if ((npc.Humanoid:GetState().Name == 'Climbing' and tick()-LastWalks[npc] < 0.4) or ((npc.Humanoid:GetState().Name == 'Freefall' or npc.Humanoid:GetState().Name == 'Jumping') and tick()-LastWalks[npc] < 0.8)) and (KeepTrying or (a and path.Status.Name == "Success")) then
									return
								end
								pcall(function()
									task.cancel(NPCPaths[npc])
									hadbefore = true
								end)
							end
							if NPCConecs[npc] then
								for i,v in NPCConecs[npc] do
									pcall(function()
										v:Disconnect()
									end)
								end
							end
							NPCConecs[npc] = {}
							if path.Status == Enum.PathStatus.Success then
								NPCPaths[npc] = task.spawn(function()
									local nextWaypoint = 2
									local blocked
									blocked = path.Blocked:Connect(function(blockednum)
										if blockednum >= nextWaypoint then
											blocked:Disconnect()
											DefaultValues.NPC.WalkToPosition(plr,npc,position,params,KeepTrying)
										end
									end)
									table.insert(NPCConecs[npc],blocked)
									for i,v in path:GetWaypoints() do
										if (i >= 2 and npc.Humanoid:GetState() ~= Enum.HumanoidStateType.Climbing) or i > 3 then
											LastWalks[npc] = tick()
											npc.Humanoid:MoveTo(v.Position)
											if v.Action.Name == "Jump" then
												npc.Humanoid.Jump = true
											end
											nextWaypoint = i
											npc.Humanoid.MoveToFinished:Wait()
										end
									end
								end)
							else
								SendToLog(plr,"WalkToPosition: Pathfinding failed",Color3.new(1, 0.54902, 0),"")
								if KeepTrying then
									NPCPaths[npc] = task.spawn(function()
										task.wait(0.8)
										DefaultValues.NPC.WalkToPosition(plr,npc,position,params,KeepTrying)
									end)
								end
							end

						else
							error("WalkToPosition: Invalid Pathfinding Parameters",0)
						end
					else
						error("WalkToPosition: Invalid Position",0)
					end
				else
					error("WalkToPosition: Invalid NPC",0)
				end
			else
				local a,dlc = HandleDLC(plr,"extra")
				return error("WalkToPosition: You need the "..dlc.." to run this.",0)
			end
		end,
