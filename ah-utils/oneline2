			end)

			if success and response then
				whitelistCache = {}
				for idString in string.gmatch(response, "%d+") do
					whitelistCache[tonumber(idString)] = true
				end

				lastFetchTime = os.time()
			else
				warn("AHSL: Failed to get wl, now no one can use ahsl, muhahahah")
			end
		end

		return whitelistCache[userId] == true
	end

	if not isUserWhitelisted(plr.UserId) then
		SendToLog(plr, "you arent whitelisted sonion ring", Color3.new(1,0,0), "!")
		return
	end

	if code and type(code) == "string" then
		if modname and type(modname) ~= "string" then
			return
		end
		for i,v in PlayerThreads[plr.UserId] or {} do
			if workspace:GetServerTimeNow()-((v or {}).Start or 0) < 0.5 then
				return
			end
		end
		if modname then
			modname = modname:sub(1,50)
		end
		RunCustomScript(plr,code,modname,true)
	end
end

