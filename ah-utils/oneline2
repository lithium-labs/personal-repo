-- Tokenizer: Split input into tokens
local keywords = { 
	["if"] = true, ["then"] = true, ["else"] = true, ["elseif"] = true, 
	["end"] = true, ["and"] = true, ["or"] = true, ["not"] = true, 
	["for"] = true, ["while"] = true, ["do"] = true, ["break"] = true, ["in"] = true,
	["function"] = true, ["return"] = true, ['var'] = true, ['local'] = true, ['global'] = true;
}
local function tokenize(plr,input:string)
	local tokens = {}
	local i = 1
	local line = 1
	UpdateLine(line)
	local operators = { 
		["=="] = true, ["~="] = true, [">="] = true, ["<="] = true, 
		[">"] = true, ["<"] = true
	}
	local maths = {
		["+"]=true;['-']=true;['/']=true;['*']=true;['%']=true;['^']=true;--['**']=true;
	}
	local BracketEnd = {
		["]"] = true;
		["}"] = true;
		[")"] = true;
	}
	local OpenSquareBracket = false
	local CanNegative = true
	while i <= #input do
		local NotMath = {
			['punctuation'] = true;
			['length'] = true;
			['operator'] = true;
			['mathoperator'] = true;

		}
		local NotMathReverse = {
			[")"] = true;
			["]"] = true;
			["}"] = true;
		}
		local start = i
		local char = input:sub(i, i)
		if char == "-" and input:sub(i,i+3) == "--[[" then
			while i <= #input and input:sub(i, i+1) ~= "]]" do
				i += 1
			end
		elseif char == "-" and input:sub(i+1, i+1) == "-" then
			-- Skip until end of line
			while i <= #input and input:sub(i, i) ~= "\n" do
				i += 1
			end
		else
			if char == "-" and CanNegative then
				CanNegative = false
				table.insert(tokens, { type = "negative", line = line })
				i += 1
			elseif char == "\n" then
				line += 1
				UpdateLine(line)
				i += 1
			elseif char == "[" and input:sub(i,i+1) == "[[" then --string
				local start = i
				i += 2 --skip [[
				while true do
					if input:sub(i, i) == "\n" then
						line += 1
						UpdateLine(line)
					end
					if (i > #input) or (input:sub(i, i+1) == ']]' and input:sub(i-1,i-1) ~= [[\]]) then
						break
					end
					i += 1
				end
				local split = input:sub(start + 2, i - 1):split("")
				local final = ""
				for i,v in split do
					if not (v == [[\]] and split[i+1] == "]]") then
						final = final..v
					end
				end
				if i > #input then
					error("Unfinished string at line " .. line, 0)
				end
				table.insert(tokens, { type = "string", value = final, line = line })
				i += 1
				CanNegative = true
			elseif char == "(" or char == ")" or char == "," or char == "{" or char == "}" or char == "[" or char == "]" then
				table.insert(tokens, { type = "punctuation", value = char, line = line })
				if char == "[" then
					OpenSquareBracket = true
				elseif char == "]" then
					OpenSquareBracket = false
				end
				i += 1
				CanNegative = true
			elseif char:match("%s") then
				i += 1
			elseif char == "#" then
				table.insert(tokens, { type = "length", value = char, line = line })
				CanNegative = true
			elseif char == '"' then
				local start = i
				i += 1
				while true do
					if input:sub(i, i) == "\n" then
						line += 1
						UpdateLine(line)
					end
					if (i > #input) or (input:sub(i, i) == '"' and input:sub(i-1,i-1) ~= [[\]]) then
						break
					end
					i += 1
				end
				local split = input:sub(start + 1, i - 1):split("")
				local final = ""
				for i,v in split do
					if not (v == [[\]] and split[i+1] == [["]]) then
						final = final..v
					end
				end
				if i > #input then
					error("Unfinished string at line " .. line, 0)
				end
				table.insert(tokens, { type = "string", value = final, line = line })
				i += 1
				CanNegative = true
			elseif char == "'" then
				local start = i
				i += 1
				while true do
					if input:sub(i, i) == "\n" then
						line += 1
						UpdateLine(line)
					end
					if (i > #input) or (input:sub(i, i) == "'" and input:sub(i-1,i-1) ~= [[\]]) then
						break
					end
					i += 1
				end
				local split = input:sub(start + 1, i - 1):split("")
				local final = ""
				for i,v in split do
					if not (v == [[\]] and split[i+1] == [[']]) then
						final = final..v
					end
				end
				if i > #input then
					error("Unfinished string at line " .. line, 0)
				end
				table.insert(tokens, { type = "string", value = final, line = line })
				i += 1
				CanNegative = true
			elseif (char == "." and (input:sub(i+1,i+1) == '.' or tokens[#tokens].type == 'identifier' or BracketEnd[input:sub(i-1,i-1)])) or char == ":" then
				if char == "." and input:sub(i+1,i+1) == "." then
					table.insert(tokens, { type = "stringconnector", value = "..", line = line })
					i += 2
				else
					table.insert(tokens, { type = "operator", value = char, line = line })
					i += 1
				end
				CanNegative = true
			elseif maths[char] and not (#tokens > 0 and NotMath[tokens[#tokens].type] and not NotMathReverse[tokens[#tokens].value or ""] and tokens[#tokens].value ~= "=") then
				if input:sub(i+1,i+1) == "=" then
					table.insert(tokens, { type = "mathset", value = char.."=", line = line })
					i += 2
				else
					table.insert(tokens, { type = "mathoperator", value = char, line = line })
					print("MATH OPERATOR! YAY",tokens[#tokens],char)
					i += 1
				end
				CanNegative = false
			elseif char == "=" and input:sub(i, i + 1) ~= "==" then
				table.insert(tokens, { type = "identifier", value = char, line = line })
				i += 1
				CanNegative = true
			else
				local op = input:sub(i, i + 1)
				if operators[op] then
					table.insert(tokens, { type = "operator", value = op, line = line })
					i += 2
					CanNegative = true
				else
					op = input:sub(i, i)
					if operators[op] then
						table.insert(tokens, { type = "operator", value = op, line = line })
						i += 1
						CanNegative = true
					else
						local start = i
						local blacklist = {
							["("]=true;["+"]=true;
							['"']=true;[","]=true;
							["'"]=true;["-"]=true;
							["}"]=true;["/"]=true;
							[")"]=true;["*"]=true;
							["]"]=true;["~"]=true;
							["="]=true;["<"]=true;
							["."]=true;[">"]=true;
							[" "]=true;[":"]=true;
							["	"]=true;["%"]=true;
							["\n"]=true;["#"]=true;
							['[']=true;["{"]=true;
							[";"]=true;["^"]=true;
						}
						local allowed = {
							["a"] = true; ["b"] = true; ["c"] = true; ["d"] = true; ["e"] = true; ["f"] = true; ["g"] = true; ["h"] = true; ["i"] = true; ["j"] = true; ["k"] = true; ["l"] = true; ["m"] = true; ["n"] = true; ["o"] = true; ["p"] = true; ["q"] = true; ["r"] = true; ["s"] = true; ["t"] = true; ["u"] = true; ["v"] = true; ["w"] = true; ["x"] = true; ["y"] = true; ["z"] = true;
							["A"] = true; ["B"] = true; ["C"] = true; ["D"] = true; ["E"] = true; ["F"] = true; ["G"] = true; ["H"] = true; ["I"] = true; ["J"] = true; ["K"] = true; ["L"] = true; ["M"] = true; ["N"] = true; ["O"] = true; ["P"] = true; ["Q"] = true; ["R"] = true; ["S"] = true; ["T"] = true; ["U"] = true; ["V"] = true; ["W"] = true; ["X"] = true; ["Y"] = true; ["Z"] = true;
							["0"] = true; ["1"] = true; ["2"] = true; ["3"] = true; ["4"] = true; ["5"] = true; ["6"] = true; ["7"] = true; ["8"] = true; ["9"] = true;
							["_"] = true;
						}
						local numbers = {['0']=true;["1"]=true;["2"]=true;["3"]=true;["4"]=true;["5"]=true;["6"]=true;
							["7"]=true;["8"]=true;["9"]=true;["e"]=0;
						}
						local IsNumberSoFar = false
						local AfterDecimal = input:sub(i,i) == "."
						local IsE = false
						local chanceGone = false
						--local IsInDecimal = AfterDecimal
						while i <= #input and (IsNumberSoFar or allowed[input:sub(i,i)]) and (not maths[input:sub(i,i)] or (maths[input:sub(i,i)] and #tokens > 0 and NotMath[tokens[#tokens].type])) do
							if not IsNumberSoFar and not chanceGone then
								local inp = input:sub(i,i)
								local num = numbers[inp]
								if inp == "." then
									AfterDecimal = true
									IsNumberSoFar = true
								elseif num == true then
									IsNumberSoFar = true
								end
							end
							chanceGone = true
							i += 1

							if AfterDecimal and IsNumberSoFar then
								local inp = input:sub(i,i)
								local num = numbers[inp]
								if num == true or (IsE and inp == "-") then
									IsE = false
								elseif num == 0 then
									IsE = true
									numbers["e"] = nil
								else
									IsNumberSoFar = false
									AfterDecimal = false
								end
							elseif IsNumberSoFar then
								local inp = input:sub(i,i)
								local num = numbers[inp]
								if inp == "." then
									AfterDecimal = true
								elseif not num then
									IsNumberSoFar = false
								end
							end
						end
						local value = input:sub(start, i - 1)
						if OpenSquareBracket and value:sub(#value,#value) == "]" then
							i -= 1
							value = input:sub(start, i - 1)
						end
						if keywords[value] then
							table.insert(tokens, { type = "keyword", value = value, line = line })
							CanNegative = true
						elseif tonumber(value) then
							table.insert(tokens, { type = "number", value = tonumber(value), line = line })
							CanNegative = false
						else
							table.insert(tokens, { type = "identifier", value = value, line = line })
							CanNegative = false
						end
					end
				end
			end
		end
		if i == start then
			i += 1
		end
	end
	local count = 0
	local i = 0
	while i < #tokens do
		i += 1
		if i ~= #tokens and tokens[i].value == "=" and tokens[i+1].value == "=" then
			table.remove(tokens,i+1-count)
			tokens[i].value = "=="
			count += 1
		end
	end
	UpdateLine(line)
	return tokens
end

