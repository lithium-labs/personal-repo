			for i,v in t do

				print("FIRST LOOP")

				local cloned = table.clone(pastEnvs)
				table.insert(cloned,1,table.clone(localEnv))
				local newLocalEnv = {}
				table.insert(PlayerLocalEnvs[plr.UserId],newLocalEnv)

				local code,ref = newref(plr)
				newLocalEnv[numname] = code
				ref[1] = nil
				ref[2] = {coroutine.running()}

				local code2,ref2 = newref(plr)
				newLocalEnv[varname] = code2
				ref2[1] = nil
				ref2[2] = {coroutine.running()}

				ref[1] = i
				ref2[1] = v
				print("MEOWMEOW",i,v,newLocalEnv)
				for _, stmt in ipairs(node.body or {}) do
					stmt = table.clone(stmt)
					UpdateLine(stmt.line)
					local doret = false
					if ThreadInfo[coroutine.running()]['evalreturn'] then
						doret = true
					end
					local result = evaluate(plr,stmt,"forg4",nil,newLocalEnv,cloned)
					if ThreadInfo[coroutine.running()]['return'] then
						return result
					end
					if doret then
						ThreadInfo[coroutine.running()]['return'] = true
						ThreadInfo[coroutine.running()]['evalreturn'] = nil
						return result
					end
					if loop_control['break'] then
						loop_control['break'] = nil
						return
					end
				end
			end

		elseif node.type == "getlength" then
			return #evaluate(plr,node.value,"gtlen",nil,localEnv,pastEnvs)
		elseif node.type == "break" then
			loop_control['break'] = true
			error("break", 0) -- Use error for control flow
		elseif n.type == "mathoperator" then
			local left = evaluate(plr,n.left,"math1",nil,localEnv,pastEnvs)
			local right = evaluate(plr,n.right,"math2",nil,localEnv,pastEnvs)
			local allowedTypes = {
				number = true;
				CFrame = true;
				Vector3 = true;
				Vector2 = true;
				UDim2 = true;
				UDim = true;
				Color3 = true;
			}
			local Tleft = typeof(left)
			local Tright = typeof(right)
			if not allowedTypes[Tleft] or not allowedTypes[Tright] then
				error('Attempt to perform arithmetic ('..(type(n.op) == 'string' and n.op or "nil")..') on '..Tleft..' and '..Tright,0)
			end
			if n.op == "+" then return left + right
			elseif n.op == "-" then return left - right
			elseif n.op == "*" then return left * right
			elseif n.op == "/" then return left / right
			elseif n.op == "%" then return left % right
			elseif n.op == "^" then return left ^ right
			else
				return error("Attempt to perform arithmetic with invalid operator: "..tostring(n.op),0)
			end
		elseif n.type == "binary" then
			local ogleft = evaluate(plr,n.left,"bin1",nil,localEnv,pastEnvs)
			local ogright = evaluate(plr,n.right,"bin2",nil,localEnv,pastEnvs)
			local left = ogleft
			local right = ogright
			if n.op == "+" then return left + right
			elseif n.op == "-" then return left - right
			elseif n.op == "*" then return left * right
			elseif n.op == "/" then return left / right
			elseif n.op == "%" then return left % right
			elseif n.op == "^" then return left ^ right
			elseif n.op == "==" then return left == right
			elseif n.op == "~=" then return left ~= right
			elseif n.op == ">=" then return left >= right
			elseif n.op == "<=" then return left <= right
			elseif n.op == ">" then return left > right
			elseif n.op == "<" then return left < right
			elseif n.op == "and" then return left and right
			elseif n.op == "or" then return left or right
			else
				return error("Attempt to perform binary with invalid operator: "..tostring(n.op),0)
			end
		elseif n.type == "unary" then
			local expr = evaluate(plr,n.expr,"bin3",nil,localEnv,pastEnvs)
			if n.op == "not" then return not expr end
		elseif n.type == "if" then

			local cloned = table.clone(pastEnvs)
			table.insert(cloned,1,table.clone(localEnv))
			local newLocalEnv = {}
			table.insert(PlayerLocalEnvs[plr.UserId],newLocalEnv)

			for i,v in node.bodies do
				if evaluate(plr,v.condition,"bin4",nil,localEnv,pastEnvs) then
					for _, stmt in ipairs(v.body) do
						UpdateLine(stmt.line)
						local doret = false
						if ThreadInfo[coroutine.running()]['evalreturn'] then
							doret = true
						end
						local r = evaluate(plr,stmt,"bin5",nil,newLocalEnv,cloned)
						if ThreadInfo[coroutine.running()]['return'] then
							return r
						end
						if doret then
							ThreadInfo[coroutine.running()]['return'] = true
							ThreadInfo[coroutine.running()]['evalreturn'] = nil
							return r
						end
					end
					break
				end
			end

		elseif node.type == "call" then

			local cloned = table.clone(pastEnvs)
			table.insert(cloned,1,table.clone(localEnv))
			local newLocalEnv = {}
			table.insert(PlayerLocalEnvs[plr.UserId],newLocalEnv)

			local newinfo = table.clone(ThreadInfo[coroutine.running()])
			newinfo.pastEnvs = cloned
			newinfo.localEnv = newLocalEnv


			ThreadInfo[coroutine.running()]['pastEnvs'] = table.clone(pastEnvs)
			table.insert(ThreadInfo[coroutine.running()]['pastEnvs'],1,table.clone(localEnv))
			-- Handle function calls like math.random()
			local func = env[node.func.value]

			if node.func.type == "member_access" then
				func = evaluate(plr,node.func,"call m-access",nil,localEnv,pastEnvs)
				if not func then
					error("Undefined function: '"..node.func.member.."'", 0)
				end
			end

			if not func then
				-- If the function is not found in the global env, check if it's a nested table access
				if node and node.func and node.func.value then
					local current = env
					local parts = {}
					for part in node.func.value:gmatch("[^%.]+") or {} do
						table.insert(parts, part)
					end
					for i = 1, #parts - 1 do
						current = current[parts[i]]
						if not current then
							error("Undefined table: " .. parts[i], 0)
						end
					end
					func = current[parts[#parts]]
					if not func and node.func.type == "identifier" then
						func = evaluate(plr,node.func,"call69",nil,localEnv,pastEnvs)
					end
				end
				if not func then
					error("Undefined function: " .. tostring(((node or {}).func or {}).value), 0)
				end
			end
			local args = {}

			if FunctionsWithPlr[func] then
				args = { plr }
			else
				for i,v in DefaultFunctions do
					if v == func then
						args = { plr }
						break
					end
				end
			end

			local isTableFunc = type(func) == "table"
			for _, arg in ipairs((node or {}).args or {}) do
				if type(arg) == "table" and (arg["value"] or arg["type"]) then
					if arg.type == "identifier" and PlayerDefaultValues[plr.UserId][arg.value] then
						--			print(1,arg)
						table.insert(args, PlayerDefaultValues[plr.UserId][arg.value])
					else
						--			print(2,arg)
						local res = evaluate(plr,arg,"call",nil,localEnv,pastEnvs)
						local whitelistedToUseFuncs = {
							[DefaultFunctions.pcall]=true;[DefaultFunctions.MakeEvent]=true;[DefaultFunctions.spawn]=true;
							[DefaultFunctions.RegisterAdonisCommand] = true;
							[DefaultValues.BindingService.BindPress] = true;
							[DefaultValues.BindingService.BindLongPress] = true;
						}
						if not whitelistedToUseFuncs[func] and type(res) == "table" and (res['type'] or ""):match("function") and not isTableFunc then
							table.insert(args,nil)
						else
							table.insert(args,res)
						end
					end
				elseif not (arg["value"] or arg["type"]) then
					table.insert(args, arg)
				end
			end

			local prints = {
				'Print','Warning','error'
			}

			local pfuncs = {}
			for i,v in prints do
				pfuncs[DefaultFunctions[v] ] = v
			end
			Verify(plr,"Call",1)
			Log(plr,'func','Call')
			if type(func) == "table" then

				local newLocalEnv = func.localEnv

				for i,v in func.args or {} do
					local code,ref = newref(plr)
					newLocalEnv[v] = code
					ref[1] = args[i]
					ref[2] = {coroutine.running()}
				end
				-- Evaluate the function body
				local result = evaluate(plr, func, "runfunctionCall",nil,localEnv,pastEnvs)
				return result
			else
				if func == DefaultFunctions.RegisterAdonisCommand then
					args[1] = {plr,newinfo}
					return func(table.unpack(args))
				elseif func == DefaultFunctions.collectgarbage then
					local num = 0
					local name = node.args[1].value
					if localEnv[name] then
						num = localEnv[name]
					else
						for i,v in pastEnvs do
							if v[name] then
								num = v[name]
								break
							end
						end
					end
					print("GARBAGECOLLECT",node)
					return func(plr,num)
				elseif pfuncs[func] then
					table.remove(args,1)
					return func(plr,args,node.line)
				elseif func == DefaultFunctions.MakeEvent then

					local cloned = table.clone(pastEnvs)
					table.insert(cloned,1,table.clone(localEnv))
					local newLocalEnv = {}
					table.insert(PlayerLocalEnvs[plr.UserId],newLocalEnv)

					local newinfo = table.clone(ThreadInfo[coroutine.running()])
					newinfo.pastEnvs = cloned
					newinfo.localEnv = newLocalEnv

					args[1] = { plr , newinfo }

					return func(table.unpack(args))
				else
					return func(table.unpack(args))
				end
			end
		elseif node.type == "instance_method_call" then

			local cloned = table.clone(pastEnvs)
			table.insert(cloned,1,table.clone(localEnv))
			local newLocalEnv = {}
			table.insert(PlayerLocalEnvs[plr.UserId],newLocalEnv)

			local newinfo = table.clone(ThreadInfo[coroutine.running()])
			newinfo.pastEnvs = cloned
			newinfo.localEnv = newLocalEnv

			local rbxsignal = {
				[InstanceFunctions.Connect] = true;
				[InstanceFunctions.Once] = true;
			}

			local instance = evaluate(plr,node.instance,"icall",nil,localEnv,pastEnvs)
			if not instance then
				return error("Attempt to call "..node.method.." on nil",0)
			end
			--	warn(node.method)
			local method = (typeof(instance) == 'userdata' and type(Instance[node.method]) == 'function' and instance[node.method]) or InstanceFunctions[node.method] or (classes[(instance or {ClassName=''}).ClassName] or {Functions={}}).Functions[node.method]
			if not method then
				if instance[node.method] then
					error("Attempt to call function using : instead of .", 0)
				else
					error("Undefined method: " .. (node.method or "nil"), 0)
				end
			end
			local args = { plr , instance }
			if typeof(instance) == 'userdata' and type(instance[node.method]) == 'function' and instance[node.method] then
				args = { instance }
			end
			for _, arg in ipairs(node.args or {}) do
				if arg["value"] or arg["type"] then
					table.insert(args, evaluate(plr,arg,"icall2",nil,localEnv,pastEnvs))
				end
			end
			if rbxsignal[method] and args[3] then
				args[4] = newinfo
			end
			print("ABOUT TO CALL CONNECT",instance,node,method,args)
			return method(table.unpack(args))

		elseif node.type == "member_access" then
			--		print("ACCESS",node)
			local tbl = evaluate(plr,node.table,"memberaccess",nil,localEnv,pastEnvs)
			local member = node.member
			if type(member) ~= "string" then
				member = evaluate(plr,member,"memberaccess2",nil,localEnv,pastEnvs)
			end
			local t = typeof(tbl)
			print("MEMBER_ACCESS:",tbl,member,t)
			--		print("ACCESS",tbl,localEnv,pastEnvs)
			if t == "Instance" then
				local ClassName = tbl.ClassName
				local property = member
				local val1 = classes[ClassName]
				if val1 then
					print("STEP1",val1)
					local val2 = (val1.Properties or {})[property]
					if val2 then
						if val2.Permissions.Get then
							return DefaultFunctions.Get(plr,tbl,member)
						end
					end
					local val3 = val1.Events[property]
					if val3 then
						print("STEP2")
						local signal
						pcall(function()
							signal = tbl[property]
						end)
						if not signal then
							signal = GetSignal(tbl,property)
						end
						print("STEP3",signal)
						if not InstancesBySignal[ signal ] then
							task.spawn(function()
								while true do
									task.wait(60)
									if not tbl or not signal or not tbl:FindFirstAncestorOfClass("DataModel") then
										break
									end
									local found = false
									for userid,tab in PlayerDefaultValues do
										for i,v in tab do
											if v == signal then
												found = true
												break
											end
										end
										if found then
											break
										end
									end
									if not found then
										break
									end
								end
								InstancesBySignal[ signal ] = nil
							end)
						end
						InstancesBySignal[ signal ] = {tbl,property}
						print("STEP4")
						return signal --RBXScriptSignal or userdata
					end
				end
				return DefaultFunctions.GetChild(plr,tbl,property)
			elseif t == "userdata" then
				return tbl[member]
			elseif t == "table" or t:match("Vector") or t:match("UDim") or t:match("Enum") or t:match("Color") or t == 'CFrame' or t == "NumberRange" or t:match("NumberSequence") or t:lower() == "BrickColor" then
				print(tbl[member])
				return tbl[member]
			else
				warn("CAN'T GET MEMBER",node,tbl,t)
				error("Can't get member of '"..t.."'",0)
			end
		elseif node.type == "member_set" then

			local tbl = evaluate(plr,node.table,"memberset",nil,localEnv,pastEnvs)
			local member,value = node.member,node.value
			if type(node.member) ~= "string" then
				member = evaluate(plr,member,"memberset2",nil,localEnv,pastEnvs)
			end
			value = evaluate(plr,value,"memberset1",nil,localEnv,pastEnvs)

			local t = typeof(tbl)
			if t == "Instance" then
				local ClassName = tbl.ClassName
				local property = member
				local val1 = classes[ClassName]
				if val1 then
					local val2 = val1.Properties[property]
					if val2 then
						if val2.Permissions.Set then
							if node.mathset then
								local old = DefaultFunctions.Get(plr,tbl,member)
								local new = value
								value = evaluate(plr,{type = "mathoperator",left = old,right = new,op = node.mathset:sub(1,1), line = node.line},"memberset3",nil,localEnv,pastEnvs)
							end
							return DefaultFunctions.Set(plr,tbl,member,value)
						end
					end
				end
				error("'"..tostring(property).."' is not a valid property of '"..tostring(ClassName).."'",0)
			elseif t == "table" or t:match("Vector") or t:match("UDim") or t:match("Enum") or t:match("Color") or t == 'CFrame' or t == "NumberRange" or t:match("NumberSequence") or t:lower() == "BrickColor" then
				if t == "table" and table.isfrozen(tbl) then
					return error("Attempted to modify a read-only table.",0)
				else
					if node.mathset then
						local old = tbl[member]
						local new = value
						value = evaluate(plr,{type = "mathoperator",left = old,right = new,op = node.mathset:sub(1,1), line = node.line},"memberset3",nil,localEnv,pastEnvs)
					end
					tbl[member] = value
				end
			elseif t == "userdata" and getmetatable(tbl) and tbl.type == "Mouse" then
				tbl[member] = value
			else
				error("Can't set property of '"..typeof(tbl).."'",0)
			end
		elseif node.value and node.value == "nil" and node.type == "identifier" then

			return nil
		elseif node.type == "stringconnector" then

			local final = ""
			local totalLength = 0
			for i,v in node.connected do
				UpdateLine((v or {}).line)
				local str = tostring(evaluate(plr,v,"connectString"..i,nil,localEnv,pastEnvs))
				totalLength += #str
				if totalLength > 500000 then
					return error("String too large (>500000)",0)
				end
				final = final..str
			end
			return final

		elseif node.type == "identifier" then

			if node.value == "_G" then
				return PlayerDefaultValues[plr.UserId]
			end

			if node.value:match("Enum") then
				if #node.value:split(".") == 3 then
					local split = node.value:split(".")
					local enum = split[1]
					local list = split[2]
					local item = split[3]
					if enum == "Enum" then
						local a,b = pcall(function()
							list = Enum[list]
						end)
						if a and list:FromName(item) then
							return list:FromName(item)
						end
					end
				end
			end

			-- Check local scope first
			print("LOCALENVIS",localEnv,pastEnvs,PlayerReferences)
			if localEnv[node.value] then
				print("RETURN1",PlayerReferences[plr.UserId][ localEnv[node.value] ][1])
				return PlayerReferences[plr.UserId][ localEnv[node.value] ][1]
			end

			for i,v in pastEnvs do
				if v[node.value] then
					if PlayerReferences[plr.UserId][v[node.value] ] then
						print("RETURN2?"..i,PlayerReferences[plr.UserId][v[node.value] ][1])
						return PlayerReferences[plr.UserId][v[node.value] ][1]
					else
						return nil
					end
				end
			end

			local val2 = PlayerDefaultValues[plr.UserId][node.value]
			if val2 ~= nil then
				print("RETURN3",PlayerDefaultValues[plr.UserId][node.value])
				return val2
			end

			local val3 = PlayerNilledValues[plr.UserId][node.value]
			if val3 then
				return nil
			end

			-- Then check global scope
			local val1 = env[node.value]
			if val1 ~= nil then
				return val1
			end

			--error("Undefined variable: " .. node.value, 0)
			return nil
		elseif node.type == "number" then
			if node.negative then
				local number = evaluate(plr,node.value,"negnum",nil,localEnv,pastEnvs)
				if type(number) == 'number' then
					return -number
				else
					return number
				end
			else
				return node.value
			end
		elseif node.type == "string" then

			return node.value
		else

			error("Unhandled node type: " .. tostring((node or {}).type), 0)
		end
	end

	local success, result = pcall(eval)
	if not success and result == "RETURN?#*827326154" then
		return error("RETURN?#*827326154",0)
	end
	if not success then
		if result:find("break") then
			return
		end
		local text = result
		if result:match("NoLineError#") then
			if NotNested then
				text = result:sub(13,#result)
			end
		elseif result:match("CustomError#") then
			if NotNested then
				text = myline or ((node or {}).line or "?").."Error#Line"..result:split("CustomError#")[2]
			end
		else
			if NotNested then
				text = myline or ((node or {}).line or "?").."Error#Line".. result
			end
		end
		error(text, 0)
	else
		if type(result) == "string" and #result > 500000 then
			return error("String too large (>500000)",0)
		end
	end
	return result
end


-- Main function to run the script
RunCustomScript = function(plr,scriptText,modname,NewModRun)
	modname = modname or "Untitled Mod"
	modname = modname:sub(1,50)
	local start = tick()
	local event = Instance.new("BindableEvent",script)
	local data = {
		Start = workspace:GetServerTimeNow();
		Script = scriptText;
		Event = event;
		Name = modname;
	}
	event.Destroying:Once(function()
		SendToLog(plr,"Script finished! "..(math.ceil((tick()-start)*1000)/1000).."ms run-time",Color3.new(0.403922, 0.403922, 0.403922),"END")
	end)
	PlayerThreads[plr.UserId][tostring(math.round(data.Start*10)/10)] = data
	data.Thread = task.spawn(function()
		local thread = coroutine.running()
		local info = {
			Name = modname;
			NewMod = NewModRun or false;
			Line = 0;
			Script = scriptText;
			Started = workspace:GetServerTimeNow();
			Thread = thread;
			Original = modname;
			OriginalThread = thread;
		}
		ThreadInfo[thread] = info
		local a,b = pcall(function()
			if NewModRun then
				Verify(plr,"RunMod",1)
			end
			local localEnv = {}
			table.insert(PlayerLocalEnvs[plr.UserId],localEnv)
			local tokens = tokenize(plr,scriptText)
			local ast = parse(plr,tokens) 
			for _, node in ipairs(ast) do
				evaluate(plr,node,"main",true,localEnv,{})
			end
		end)
		if not a then
			warn(b)
			if b:match("Error#Line") then
				if b:find(script:GetFullName(),1,true) then
					b = b:split("Error#Line")[1].."Error#Line".."An internal AHSL error occured. Blame Gusta for his slop code."
				end
				local txt = ""
				for i,v in b:split("Error#Line") do
					if i ~= 1 then
						txt = txt..v
					end
				end
				local line = b:split("Error#Line")[1]
				if line == "?" then
					line = tostring(info.Line)
				end
				SendToLog(plr,txt,Color3.new(0.8,0,0),b:split("Error#Line")[1])
			else
				if b:find(script:GetFullName(),1,true) then
					b = "An internal AHSL error occured. Blame Gusta for his slop code."
				end
				SendToLog(plr,b,Color3.new(0.8,0,0),info.Line)
			end
		end
		event:Destroy()
		PlayerThreads[plr.UserId][tostring(math.round(data.Start*10)/10)] = nil
		ClearReferences(plr)
	end)
end

