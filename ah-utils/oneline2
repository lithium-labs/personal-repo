	end
	local tab,size = table.dupe(cache[plr.UserId])
	tab.ByteSize = size
	for i,v in tab.Mods do
		v.ModSize = rawlen(encode(v))
		--total += (4+v.ModSize)
		v.RawScriptLength = rawlen(v.Script)
		v.ScriptLength = #v.Script
		if DontGetMods then
			v.Script = nil
		end
		for q,z in v.Storage.Builds do
			z.Serialized = nil --We dont want exploiters figuring out how we save data!!!
		end
		for q,z in v.Storage.Variables do
			v.Storage.Variables[q] = typeof(z)
		end
	end
	return tab
end

