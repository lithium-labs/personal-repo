				if len > 1_000_000 then --1MB is mod size limit
					return error("SaveInstance: This mod reached the 1000KB (1MB) size limit. Size: "..math.round(len/1000).."KB",0)
				end
				local data = Serializer.Serialize({instance})
				len += rawlen(data)
				if len > 1_000_000 then
					return error("SaveInstance: This mod reached the 1000KB (1MB) size limit. Size: "..math.round(len/1000).."KB",0)
				end
				mod.Storage.Builds[varname] = {
					['Serialized'] = data,
					['SavedAt'] = math.round(workspace:GetServerTimeNow());
					['InstanceName'] = clone.Name:sub(1,500);
					['ClassName'] = clone.ClassName;
					['InstanceCount'] = #clone:GetDescendants()+1;
					['ByteSize'] = rawlen(data);
				}
				clone:Destroy()
				return true
			elseif instance == nil then
				local plrmods = cache[plr.UserId]['Mods']
				local mod = plrmods[ThreadInfo[coroutine.running()].Original]
				if not mod then
					return error("SaveInstance: You must save this mod to use the mod's storage.",0)
				end
				mod.Storage.Builds[varname] = nil
				return true
			else
				return error("SaveInstance: Invalid instance",0)
			end
		else
			return error("SaveInstance: Invalid variable name. Must be a string.",0)
		end
