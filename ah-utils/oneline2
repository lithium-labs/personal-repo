			if classname and classes[classname] then
				if classes[classname]["NonCreatable"] then
					return error("Instance.new: '"..classname.."' is not a creatable instance-type",0)
				end
				if not RankAllowed(plr, classes[classname]) then
					return error("Instance.new: You do not have the required rank to create '"..classname.."'",0)
				end
				if classes[classname]['UI'] and not dlc then
					return error("Instance.new: To create UI you need the Extra Features Expansion",0)
				end
				if not parent or typeof(parent) ~= "Instance" then
					return error("Instance.new: No parent given (Instance.new(Class,Parent))",0)
				end
				if classes[classname]["Deprecated"] then
					local Warning = classes[classname].DeprecationWarning or "'"..classname.."' is deprecated. Avoid usage of this object"
					SendToLog(plr,Warning,Color3.new(1, 0.54902, 0),"!")
				end
				local isplayergui = false
				if parent ~= plr.PlayerGui then
					local ancestor = parent:FindFirstAncestorOfClass("PlayerGui")
					if ancestor and ancestor ~= plr.PlayerGui then
						return error("Instance.new: Can only parent UI to your own screen")
					elseif ancestor then
						isplayergui = true
					end
				else
					isplayergui = true
				end
				if isplayergui and not dlc then
					return error("Instance.new: To parent Instances to UI you need the Extra Features Expansion",0)
				end
				if isplayergui and not classes[classname]['UI'] then
					return error("Instance.new: You can't parent anything other than UI to your screen")
				end
				local function valid(i,v)
					if classes[v.ClassName] and (not classes[v.ClassName]["NotParentableTo"] or (isplayergui and (v == plr or v == game.Players))) and not v:HasTag("DefaultUI") and v.Name ~= "SecureParts" then
						return true
					else
						return error("Instance.new: Ancestor "..i.." '"..v.Name.."' is not ParentableTo",0)
					end
				end
				valid(0,parent)
				for i,v in GetAncestors(parent) do
					valid(i,v)
				end
				local new = Instance.new(classname)
				new:AddTag("CreatedWithAHSL")
				if properties and type(properties) == "table" then
					print("ok nice")
					local a,b = pcall(function()
						for i,v in properties do
							DefaultFunctions.Set(plr,new,i,v)
						end
					end)
					if not a then
						new:Destroy()
						warn(b)
						return error("Error while setting "..classname.."'s properties: "..b,0)
					end
				end
				if new:IsA("BasePart") then
					if not new.Anchored then
						Verify(plr,"UnanchorPart",1)
					end
					local Success = AHPartAntiLag.Register(new,plr,true,true)
					if not Success then
						new:Destroy()
						return error("Clone: You have reached the part count limit",0)
					end
				end
				new.Parent = parent
				return new
			else
				return error("Instance.new: '"..(classname or "nil").."' is not a valid instance-type",0)
			end
		end,
