local function unixToTime(unixTime)
	unixTime = tonumber(unixTime)
	local dateTime = os.date("*t", unixTime)
	local hour = string.format("%02d", dateTime.hour)
	local minute = string.format("%02d", dateTime.min)
	return string.format("%s:%s", hour, minute)
end

local function BetterToString(text)
	if typeof(text) == "Instance" then
		text = text.Name:sub(1,30)..":"..text.ClassName
	elseif typeof(text):match("Enum") then
	elseif type(text) == "table" then
		text = "table"
	elseif type(text) == "boolean" then
	elseif type(text) == "number" then
	elseif typeof(text) == "function" then
		local func
		pcall(function()
			for i,v in DefaultFunctions do
				if v == text then
					func = i
					return
				end
			end
			for i,v in DefaultValues do
				if type(v) == "table" then
					for q,z in v do
						if z == text then
							func = q
							return
						end
					end
				elseif v == text then
					func = i
					return
				end
			end
			func = "func"
		end)
	elseif type(text) == "string" then
		text = '"'..text..'"'
	else
		text = typeof(text).."("..tostring(text)..")"
	end
	text = tostring(text)
	return text
end

local function Log(plr,action,...)
	local tab = {...}
	if action == "func" then
		local funcName = tostring(tab[1])
		local args = {}
		for i,v in tab do
			if i > 1 then
				table.insert(args,BetterToString(v))
			end
		end
		local tim = workspace:GetServerTimeNow()
		local finalstr = unixToTime(tim).." @"..plr.Name..": "..funcName.."("
		for i,v in args do
			if i == 1 then
				finalstr = finalstr..v
			else
				finalstr = finalstr..", "..v
			end
		end
		finalstr = finalstr..")"
		--local key = tostring(math.round((99999999999-tick())*100000))
		table.insert(Logs,{
			['time'] = tim;
			['timestamp'] = unixToTime(tim);
			['player'] = plr;
			['userid'] = plr.UserId;
			['username'] = plr.Name;
			['displayname'] = plr.DisplayName;
			['action'] = action;
			['args'] = tab;
			['toshow'] = finalstr;
