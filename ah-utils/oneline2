local function SafeParent(plr,classname,parent)
	local endnow = false
	local function valid(i,v)
		if classes[v.ClassName] and (not classes[v.ClassName]["NotParentableTo"]) and not v:HasTag("DefaultUI") and v.Name ~= "SecureParts" and (v.ClassName ~= 'PlayerGui' or (v == plr.PlayerGui and classes[classname].UI and HandleDLC(plr,'extra'))) then
			if v == plr.PlayerGui then
				endnow = true
			end
			return true
		else
			return false
		end
	end
	local res = valid(0,parent)
	if not res then
		return false
	end
	for i,v in GetAncestors(parent) do
		local res = valid(i,v)
		if not res then
			return false
		end
		if endnow then
			break
		end
	end
	return true
end

