						warn(v)
						if v and typeof(v) == "Instance" and not classes[v.ClassName] then
							results[i] = nil
							if #results == 0 then
								return
							end
						end
					end
					return unpack(results)
				end
			else
				return error("Event.Wait: The event's reference data does not exist. Did you put an Event in a table?",0)
			end

		else
			return error("Event.Wait: Attempt to use a '"..(typeof(conec) or "nil").."' as an Event",0)
		end
	end,
	Disconnect = function(plr,conec)
		if conec and (typeof(conec) == "RBXScriptConnection" or (typeof(conec) == 'userdata' and conec.type == 'RBXScriptConnection')) then
			local eventname = InstancesBySignal[conec]
			if eventname and type(eventname) == "string" then
				return DefaultFunctions.DeleteEvent(plr,eventname)
			else
				return error("Disconnect: Weird behavior",0)
			end
		else
			return error("Disconnect: Invalid Event to disconnect",0)
		end
	end,
}

