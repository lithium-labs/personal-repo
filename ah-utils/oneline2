local function OnPlayerJoin(plr)
	PlayerDefaultValues[plr.UserId] = {
		['LocalPlayer'] = plr;
		['MyPlayer'] = plr;
		['MyPlr'] = plr;
		['localplr'] = plr;
	}
	PlayerLocalEnvs[plr.UserId] = {}
	PlayerReferences[plr.UserId] = {}
	PlayerNilledValues[plr.UserId] = {}
	PlayerEvents[plr.UserId] = {}
	PlayerThreads[plr.UserId] = {}
	PlayerStartAA[plr.UserId] = tick()
	module.PlayerCommands[plr.UserId] = {}
	local a,data = RBXUtility.RetryWithLimit(datastore.GetAsync,true,"AHSL, getting mods for "..plr.UserId.." fail: ",0.5,5,datastore,tostring(plr.UserId))
	if not a then
		task.wait(1)
		require(game.ServerStorage.ServerModules.PromptService).Prompt(plr,"Failed to load mods","Failed to load your mods, rejoin if necessary")
	else
		if not data then
			data = {
				['CreatedAt'] = math.round(workspace:GetServerTimeNow());
				['Version'] = 2;
				['Mods'] = {};
			}
		end
		if data.Version == 1 then --this version had no Storage in mods
			for i,v in data.Mods do
				if not v.Storage then
					v.Storage = {Builds={};Variables={};Other={};}
				end
			end
			data.Version = 2
		end
		cache[plr.UserId] = data
	end
	local c = 0
	repeat task.wait() until RunCustomScript and GS and _G.ServerCoreLoaded
	--print"alright lets start AHSL "
	local gscache = GS.GetCache()[tostring(plr.UserId)]
	if gscache and (gscache.Gamepasses.PermAdmin.Owned or gscache.Gamepasses.PermAdmin.Gifted) then
		for i,mod in data.Mods do
			local code = mod.Script
			--print("AHSL "..code:sub(1,10))
			if code and code:sub(1,10) == "--!startup" then
				task.spawn(function()
					--print"AHSL nice lets run it"
					RunCustomScript(plr,mod.Script,mod.Name,true)
				end)
				c += 1
				if c >= 3 then
					break
				end
			end
		end
	end
end

